# Database URL for SQLAlchemy (MySQL)
# Format: mysql+pymysql://username:password@localhost:3306/database_name
MYSQL_URL=mysql+pymysql://root:YOUR_PASSWORD@localhost:3306/portfolio_db

# Secret value stored in the HttpOnly session cookie (use a long random string in production)
SESSION_SECRET=portfolio-admin-session-secret-2024

# Default admin login password (must be 8+ chars and contain uppercase, lowercase, number, and special character)
ADMIN_PASSWORD=YOUR_SECURE_ADMIN_PASSWORD

# Default admin login email address
ADMIN_EMAIL=admin@example.com

# Server Port
PORT=8000
