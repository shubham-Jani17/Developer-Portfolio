# Copy to .env in Portfolio/

# EmailJS (optional — contact still saves to admin inbox via API)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# API (leave empty in dev — Vite proxies /api to localhost:3001)
VITE_API_URL=

# Server (server/.env or set when running npm run server)
ADMIN_PASSWORD=admin123
JWT_SECRET=change-this-secret-in-production
PORT=3001
